/**
 * @description Simple Calculator class for demonstration purposes
 * Contains multiple methods to demonstrate test coverage scenarios
 */
public with sharing class Calculator {
    
    /**
     * @description Adds two numbers
     * @param a First number
     * @param b Second number
     * @return Sum of a and b
     */
    public static Decimal add(Decimal a, Decimal b) {
        return a + b;
    }
    
    /**
     * @description Subtracts two numbers
     * @param a First number
     * @param b Second number
     * @return Difference of a and b
     */
    public static Decimal subtract(Decimal a, Decimal b) {
        return a - b;
    }
    
    /**
     * @description Multiplies two numbers
     * @param a First number
     * @param b Second number
     * @return Product of a and b
     */
    public static Decimal multiply(Decimal a, Decimal b) {
        return a * b;
    }
    
    /**
     * @description Divides two numbers
     * @param a Numerator
     * @param b Denominator
     * @return Quotient of a and b
     * @throws IllegalArgumentException if b is zero
     */
    public static Decimal divide(Decimal a, Decimal b) {
        if (b == 0) {
            throw new IllegalArgumentException('Cannot divide by zero');
        }
        return a / b;
    }
    
    /**
     * @description Calculates the power of a number
     * @param base Base number
     * @param exponent Exponent
     * @return base raised to the power of exponent
     */
    public static Decimal power(Decimal base, Integer exponent) {
        if (exponent == 0) {
            return 1;
        }
        
        Decimal result = base;
        for (Integer i = 1; i < Math.abs(exponent); i++) {
            result *= base;
        }
        
        if (exponent < 0) {
            return 1 / result;
        }
        
        return result;
    }
    
    /**
     * @description Calculates the square root of a number
     * @param num Number to calculate square root for
     * @return Square root of num
     * @throws IllegalArgumentException if num is negative
     */
    public static Decimal squareRoot(Decimal num) {
        if (num < 0) {
            throw new IllegalArgumentException('Cannot calculate square root of negative number');
        }
        
        if (num == 0) {
            return 0;
        }
        
        return Math.sqrt(num.doubleValue());
    }
    
    /**
     * @description Checks if a number is even
     * @param num Number to check
     * @return true if even, false if odd
     */
    public static Boolean isEven(Integer num) {
        return Math.mod(num, 2) == 0;
    }
    
    /**
     * @description Calculates factorial of a number
     * @param num Number to calculate factorial for
     * @return Factorial of num
     * @throws IllegalArgumentException if num is negative
     */
    public static Integer factorial(Integer num) {
        if (num < 0) {
            throw new IllegalArgumentException('Cannot calculate factorial of negative number');
        }
        
        if (num == 0 || num == 1) {
            return 1;
        }
        
        Integer result = 1;
        for (Integer i = 2; i <= num; i++) {
            result *= i;
        }
        
        return result;
    }
}
